# Salin menjadi .env.runner pada host Linux self-hosted; jangan commit file hasil salinan.
GITHUB_REPOSITORY_URL=https://github.com/davinbennett/aegira-creditappdemo-cicd
GITHUB_RUNNER_TOKEN=replace-with-a-new-github-pat
RUNNER_NAME=laptop-runner
RUNNER_LABELS=docker-local

# Path ini harus absolut dan sama persis pada host serta di dalam container runner.
RUNNER_WORKDIR=/tmp/aegira-creditappdemo-runner
RUNNER_DATA_DIR=./runner-data
